{
  "name": "clawscreen",
  "version": "1.1.0",
  "description": "ClawScreen: an OpenClaw-native A2UI prompt-to-screen HUD prototype",
  "license": "MIT",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/recursive-systems/clawscreen.git"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "rm -rf dist/server && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/server.js",
    "test:curl": "curl -sS -X POST http://127.0.0.1:18841/a2ui/generate -H 'Content-Type: application/json' -d '{\"prompt\":\"Show me my top 3 priorities today\"}' | jq ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
