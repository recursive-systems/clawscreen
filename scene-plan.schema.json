{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://family-hud.local/scene-plan.schema.json",
  "title": "Family HUD Scene Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAt",
    "title",
    "mode",
    "theme",
    "ttlSeconds",
    "cards"
  ],
  "properties": {
    "version": { "const": "1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "mode": { "type": "string", "enum": ["brief", "focus", "deep"] },
    "theme": { "type": "string", "enum": ["dark", "light"] },
    "ttlSeconds": { "type": "integer", "minimum": 30, "maximum": 3600 },
    "cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "priority", "size", "title", "data"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "pattern": "^(agenda|weather|tasks|notes|summary|alerts|x-[a-z0-9-]+)$"
          },
          "priority": { "type": "integer", "minimum": 1, "maximum": 99 },
          "size": { "type": "string", "enum": ["small", "medium", "large"] },
          "title": { "type": "string", "minLength": 1 },
          "data": { "type": "object" }
        }
      }
    },
    "highlights": {
      "type": "array",
      "items": { "type": "string" }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
